# ─── StudyPal Backend Environment Variables ────────────────────────────────────
# Copy this to .env and fill in your values

# MongoDB Connection
# Local: mongodb://localhost:27017/studypal
# Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/studypal
MONGO_URI=mongodb://localhost:27017/studypal

# Server Port
PORT=3001

# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

NODE_ENV=development
